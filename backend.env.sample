########################################
#        Other Settings                #
########################################
TZ=Asia/Taipei

########################################
#           LDAP  Settings             #
########################################
LEVERET_AUTH_LDAP_ENABLE=false
LEVERET_AUTH_LDAP_FILE_PATH=

########################################
#        Group Settings                #
########################################
GROUP_USE=true
GROUP_TEMPLATE_SHARE_ENABLE=true

########################################
#        Callback Settings             #
########################################
CALLBACK_HOST=http://127.0.0.1
CALLBACK_ENABLE_TASK_COMPLETED=false
CALLBACK_ENABLE_ENVELOPE_COMPLETED=false
CALLBACK_ENABLE_STAGE_DONE=false
TASK_COMPLETED_PATH=/callback/task
ENVELOPE_COMPLETED_PATH=/callback/envelope
STAGE_DONE_PATH=/callback/stage
COMPRESS_SIGNATURE_PHOTO_FILE=false
COMPRESS_SIGNATURE_STROKE_FILE=false
COMPRESS_SIGNATURE_VIDEO_FILE=false

########################################
#        SignTask Settings             #
########################################
WITH_SIGN_URL_ENABLE=true

########################################
#           KMPDF Settings             #
########################################
FONT_FOLDER_ENABLE=false
CUSTOM_FONT_NAME=
CUSTOM_FONT_PATH=
