########################################
#    Frontend Environment Settings     #
########################################
# SECURITY NOTICE: every sample value in this file is publicly known.
# AUTH_CLIENT_ID / AUTH_CLIENT_SECRET must be IDENTICAL to the values in
# backend.env — the backend seeds this OAuth client at first boot, and the
# frontend uses the same pair to obtain tokens. When you replace them
# (openssl rand -hex 32), update BOTH files together.

# Base URL the browser uses to reach the API.
# Leave empty to use the same origin as the site (recommended behind the
# bundled nginx). NOTE: this value is baked into the client bundle at image
# BUILD time — pass it as a build argument (see docker-compose.yml);
# setting it here only affects the server side at runtime.
NEXT_PUBLIC_API_HOST=

# Internal URL the frontend server uses to reach the backend container.
# The default matches the service name in docker-compose.yml.
BACKEND_HOST=http://on_premise_backend:3000

# OAuth client credentials — must match AUTH_CLIENT_ID / AUTH_CLIENT_SECRET
# in backend.env.
AUTH_CLIENT_ID=bb609dbb6798aab06df1ed785a497df218a1c31cc1e1212690e7069a3495c8dd
AUTH_CLIENT_SECRET=61d3fced5b5e226dd07c8e60ab5f5e7f59e758979a9f1c3b08d8853afd25fc89
